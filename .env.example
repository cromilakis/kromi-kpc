# Supabase
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>

# WhatsApp CTA de la landing (inlined en build por Next)
NEXT_PUBLIC_WHATSAPP_NUMBER=56900000000

# LLM para autocompletado del diagnóstico desde transcripción (DeepSeek,
# API compatible con OpenAI). SERVER-ONLY: nunca uses el prefijo NEXT_PUBLIC
# (la clave jamás debe llegar al navegador). Vacío => función deshabilitada.
DEEPSEEK_API_KEY=<server-only-deepseek-api-key>

# Stripe (pagos del portal del cliente — Fase 2). SERVER-ONLY: nunca NEXT_PUBLIC.
# En dev usar claves de TEST. RECOMENDADO: usar una restricted API key (rk_test_…/
# rk_live_…) con permisos mínimos (Checkout Sessions write, PaymentIntents read)
# en vez de la secret key (sk_) — un rk_ comprometido hace mucho menos daño. El
# código acepta rk_ o sk_ en esta misma variable. El webhook secret (whsec_…) sale
# de configurar el endpoint en el dashboard de Stripe o de `stripe listen` en local.
STRIPE_SECRET_KEY=<server-only-stripe-restricted-or-secret-key-test>
STRIPE_WEBHOOK_SECRET=<server-only-stripe-webhook-signing-secret>

# Sentry -- DSN público (client+server). Vacío => Sentry deshabilitado (no-op).
NEXT_PUBLIC_SENTRY_DSN=<your-sentry-dsn>
# Solo en build/CI: subida de source maps. Sin token el SDK funciona igual.
SENTRY_ORG=<your-sentry-org-slug>
SENTRY_PROJECT=<your-sentry-project-slug>
SENTRY_AUTH_TOKEN=<build-only-source-map-upload-token>
